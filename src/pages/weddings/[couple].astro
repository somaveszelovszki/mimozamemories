---
import BlankLayout from '@/layouts/BlankLayout.astro'
import type { WeddingPortfolio } from '@/assets/data/weddings'
import { weddingPortfolios } from '@/assets/data/weddings'

export function getStaticPaths() {
  return weddingPortfolios.map(portfolio => ({
    params: { couple: portfolio.slug },
    props: { portfolio }
  }))
}

interface Props {
  portfolio: WeddingPortfolio
}

const { portfolio } = Astro.props as Props

const pageTitle = `${portfolio.name} | Esküvői portfólió | Mimóza Memories`
const pageDescription = `${portfolio.name} esküvői dekorációs portfóliója. ${portfolio.caption}`
const pageImage = portfolio.coverImage
---

<BlankLayout title={pageTitle} description={pageDescription} image={pageImage}>
  <section class='bg-background text-foreground mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-18'>
    <a
      href='/#testimonials'
      class='text-primary hover:text-primary/80 focus-visible:ring-ring inline-flex items-center gap-2 text-sm font-medium underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2'
    >
      Vissza a párokhoz
    </a>

    <header class='mt-6 space-y-3 sm:mt-8'>
      <h1 class='font-serif text-3xl font-semibold sm:text-4xl lg:text-5xl'>{portfolio.name}</h1>
      <p class='text-muted-foreground max-w-3xl text-lg'>{portfolio.caption}</p>
    </header>
  </section>

  <section class='mx-auto max-w-6xl px-4 pb-10 sm:px-6 sm:pb-14 lg:px-8 lg:pb-18'>
    <div id='wedding-gallery' class='columns-1 gap-4 sm:columns-2 lg:columns-3' data-images={JSON.stringify(portfolio.images)}>
      {portfolio.images.map((image, index) => (
        <figure class='mb-4 break-inside-avoid overflow-hidden rounded-lg'>
          <button
            type='button'
            data-gallery-index={index}
            aria-label={`${index + 1}. kép megnyitása`}
            class='focus-visible:ring-ring hover:border-primary group block w-full cursor-pointer rounded-lg border border-transparent outline-none transition-colors duration-300 focus-visible:ring-2 focus-visible:ring-offset-2'
          >
            <img
              src={image}
              alt={`${portfolio.name} esküvői galéria kép ${index + 1}`}
              class='h-auto w-full object-cover transition-transform duration-300 group-hover:scale-105'
              loading='lazy'
            />
          </button>
        </figure>
      ))}
    </div>
  </section>

  <div
    id='gallery-lightbox'
    class='bg-background/95 fixed inset-0 z-50 hidden items-center justify-center p-4 backdrop-blur-sm sm:p-8'
    aria-hidden='true'
  >
    <button
      type='button'
      id='gallery-close'
      class='bg-background/70 text-foreground hover:bg-background absolute top-4 right-4 z-10 rounded-full border px-3 py-1.5 text-sm'
      aria-label='Galéria bezárása'
    >
      Bezárás
    </button>

    <button
      type='button'
      id='gallery-prev'
      class='bg-background/70 text-foreground hover:bg-background absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full border px-3 py-2 text-2xl leading-none'
      aria-label='Előző kép'
    >
      ‹
    </button>

    <img id='gallery-image' src='' alt='' class='max-h-[90vh] max-w-full rounded-xl object-contain' />

    <button
      type='button'
      id='gallery-next'
      class='bg-background/70 text-foreground hover:bg-background absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full border px-3 py-2 text-2xl leading-none'
      aria-label='Következő kép'
    >
      ›
    </button>
  </div>

  <script is:inline>
    ;(() => {
      const cleanupKey = '__mimozaWeddingGalleryCleanup'

      const initWeddingGallery = () => {
        if (typeof window[cleanupKey] === 'function') {
          window[cleanupKey]()
        }

        const gallery = document.querySelector('#wedding-gallery')
        const lightbox = document.querySelector('#gallery-lightbox')
        const lightboxImage = document.querySelector('#gallery-image')
        const closeButton = document.querySelector('#gallery-close')
        const prevButton = document.querySelector('#gallery-prev')
        const nextButton = document.querySelector('#gallery-next')

        if (!gallery || !lightbox || !lightboxImage || !closeButton || !prevButton || !nextButton) {
          window[cleanupKey] = null
          return
        }

        const images = JSON.parse(gallery.getAttribute('data-images') || '[]')
        if (!Array.isArray(images) || images.length === 0) {
          window[cleanupKey] = null
          return
        }

        let activeIndex = 0

        const openLightbox = index => {
          activeIndex = index
          lightboxImage.setAttribute('src', images[activeIndex])
          lightboxImage.setAttribute('alt', `${activeIndex + 1}. esküvői galéria kép`)
          lightbox.classList.remove('hidden')
          lightbox.classList.add('flex')
          lightbox.setAttribute('aria-hidden', 'false')
          document.body.style.overflow = 'hidden'
        }

        const closeLightbox = () => {
          lightbox.classList.add('hidden')
          lightbox.classList.remove('flex')
          lightbox.setAttribute('aria-hidden', 'true')
          document.body.style.overflow = ''
        }

        const showRelative = direction => {
          activeIndex = (activeIndex + direction + images.length) % images.length
          lightboxImage.setAttribute('src', images[activeIndex])
          lightboxImage.setAttribute('alt', `${activeIndex + 1}. esküvői galéria kép`)
        }

        const onGalleryClick = event => {
          const trigger = event.target.closest('[data-gallery-index]')
          if (!trigger) {
            return
          }
          const index = Number(trigger.getAttribute('data-gallery-index'))
          if (!Number.isFinite(index)) {
            return
          }
          openLightbox(index)
        }

        const onPrevClick = () => showRelative(-1)
        const onNextClick = () => showRelative(1)

        const onLightboxClick = event => {
          if (event.target === lightbox) {
            closeLightbox()
          }
        }

        const onKeyDown = event => {
          if (lightbox.getAttribute('aria-hidden') === 'true') {
            return
          }
          if (event.key === 'Escape') {
            closeLightbox()
          } else if (event.key === 'ArrowLeft') {
            showRelative(-1)
          } else if (event.key === 'ArrowRight') {
            showRelative(1)
          }
        }

        gallery.addEventListener('click', onGalleryClick)
        closeButton.addEventListener('click', closeLightbox)
        prevButton.addEventListener('click', onPrevClick)
        nextButton.addEventListener('click', onNextClick)
        lightbox.addEventListener('click', onLightboxClick)
        document.addEventListener('keydown', onKeyDown)

        window[cleanupKey] = () => {
          gallery.removeEventListener('click', onGalleryClick)
          closeButton.removeEventListener('click', closeLightbox)
          prevButton.removeEventListener('click', onPrevClick)
          nextButton.removeEventListener('click', onNextClick)
          lightbox.removeEventListener('click', onLightboxClick)
          document.removeEventListener('keydown', onKeyDown)
          document.body.style.overflow = ''
        }
      }

      initWeddingGallery()
      document.addEventListener('astro:page-load', initWeddingGallery)
    })()
  </script>
</BlankLayout>
