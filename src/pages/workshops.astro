---
import WorkshopsCalendar from '@/components/blocks/workshops-section/workshops-calendar'
import { upcomingWorkshops, workshopPortfolios } from '@/assets/data/workshops'
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Workshopok | Mimóza Memories'
const pageDescription =
  'Nézd meg a korábbi Mimóza Memories workshopokat, jelentkezz a következő alkalmakra, és kövesd a workshop naptárat.'

const workshopsCalendarEvents = [
  ...workshopPortfolios.map(workshop => ({
    title: workshop.title,
    date: workshop.date,
    location: workshop.location,
    facebookEventUrl: workshop.facebookEventUrl,
    registrationUrl: workshop.registrationUrl,
    isPast: true
  })),
  ...upcomingWorkshops.map(workshop => ({
    title: workshop.title,
    date: workshop.date,
    time: workshop.time,
    location: workshop.location,
    facebookEventUrl: workshop.facebookEventUrl,
    registrationUrl: workshop.registrationUrl,
    isPast: false
  }))
]
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='bg-background text-foreground mx-auto flex w-full max-w-6xl flex-col gap-4 px-4 py-10 sm:px-6 sm:py-14 lg:px-8'>
    <h1 class='font-serif text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl'>Workshopok</h1>
    <p class='text-muted-foreground max-w-3xl text-lg'>
      Itt találod a korábbi workshopok összefoglalóit és a következő alkalmakat. Minden workshophoz külön Facebook
      esemény és Google Forms jelentkezés tartozik.
    </p>
  </section>

  <section id='past-workshops' class='mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12'>
    <div class='mb-6 flex items-end justify-between gap-4'>
      <h2 class='font-serif text-2xl font-semibold sm:text-3xl'>Korábbi workshopok</h2>
      <p class='text-muted-foreground text-sm sm:text-base'>Galériák és részletek</p>
    </div>

    <div class='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'>
      {workshopPortfolios.map(workshop => (
        <article class='border-border hover:border-primary overflow-hidden rounded-xl border bg-card transition-colors duration-300'>
          <a href={`/workshops/${workshop.slug}`} class='group block'>
            <img
              src={workshop.coverImage}
              alt={`${workshop.title} borítókép`}
              class='h-52 w-full object-cover transition-transform duration-300 group-hover:scale-105'
              loading='lazy'
            />
            <div class='space-y-3 p-5'>
              <h3 class='font-serif text-xl font-medium'>{workshop.title}</h3>
              <p class='text-muted-foreground text-sm'>{workshop.date} - {workshop.location}</p>
              <p class='text-muted-foreground text-sm leading-relaxed'>{workshop.caption}</p>
              <span class='text-primary text-sm font-medium'>Galéria megnyitása</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section id='upcoming-workshops' class='bg-muted/40 py-10 sm:py-12 lg:py-14'>
    <div class='mx-auto max-w-6xl px-4 sm:px-6 lg:px-8'>
      <div class='mb-8 space-y-3'>
        <h2 class='font-serif text-2xl font-semibold sm:text-3xl'>Következő workshopok</h2>
        <p class='text-muted-foreground max-w-3xl text-lg'>
          Válaszd ki a neked tetsző eseményt, csatlakozz a Facebook eseményhez, és küldd el a jelentkezést Google
          Forms-on.
        </p>
      </div>

      <div class='grid grid-cols-1 gap-6 lg:grid-cols-3'>
        {upcomingWorkshops.map(workshop => (
          <article class='border-border rounded-xl border bg-background p-5'>
            <h3 class='font-serif text-xl font-medium'>{workshop.title}</h3>
            <p class='text-muted-foreground mt-2 text-sm'>
              {workshop.date} - {workshop.time}
            </p>
            <p class='text-muted-foreground text-sm'>{workshop.location}</p>
            <p class='text-muted-foreground mt-3 text-sm leading-relaxed'>{workshop.description}</p>
            <div class='mt-5 flex flex-wrap gap-3'>
              <a
                href={workshop.facebookEventUrl}
                target='_blank'
                rel='noreferrer'
                class='bg-primary text-primary-foreground hover:bg-primary/90 rounded-full px-4 py-2 text-sm font-medium'
              >
                Facebook esemény
              </a>
              <a
                href={workshop.registrationUrl}
                target='_blank'
                rel='noreferrer'
                class='border-border bg-background hover:bg-muted rounded-full border px-4 py-2 text-sm font-medium'
              >
                Jelentkezés
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id='workshops-calendar' class='mx-auto w-full max-w-[74rem] px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14'>
    <div class='mb-6 space-y-3'>
      <h2 class='font-serif text-2xl font-semibold sm:text-3xl'>Workshop naptár</h2>
      <p class='text-muted-foreground max-w-3xl text-lg'>
        Interaktív naptár, ahol minden korábbi és következő workshop dátuma egy helyen látható.
      </p>
    </div>
    <WorkshopsCalendar events={workshopsCalendarEvents} client:visible />
  </section>
</Layout>
